#!/usr/bin/env python3
"""est 拡張フィルタ: office文書等をプレーンテキスト化
estcmd の -fx から `estfx <infile> <outfile>` で呼ばれ、テキストを <outfile> に書く(T@)"""
import os,subprocess,sys

def _docx(p):
    from docx import Document
    return "\n".join(x.text for x in Document(p).paragraphs)

def _xlsx(p):
    from openpyxl import load_workbook
    o=[]
    for ws in load_workbook(p,read_only=True,data_only=True).worksheets:
        o.append("# "+ws.title)
        for row in ws.iter_rows(values_only=True):
            c=[str(v) for v in row if v is not None]
            if c:o.append("\t".join(c))
    return "\n".join(o)

def _pptx(p):
    from pptx import Presentation
    o=[]
    for s in Presentation(p).slides:
        for sh in s.shapes:
            if sh.has_text_frame and sh.text_frame.text:o.append(sh.text_frame.text)
    return "\n".join(o)

def _doc(p):
    return subprocess.run(["antiword",p],capture_output=True,text=True).stdout

def _rtf(p):
    from striprtf.striprtf import rtf_to_text
    return rtf_to_text(open(p,encoding="utf-8",errors="ignore").read())

def _pdf(p):
    return subprocess.run(["pdftotext","-enc","UTF-8",p,"-"],capture_output=True,text=True).stdout

CONV={".docx":_docx,".xlsx":_xlsx,".pptx":_pptx,".doc":_doc,".rtf":_rtf,".pdf":_pdf}

def main():
    infile,outfile=sys.argv[1],sys.argv[2]
    fn=CONV.get(os.path.splitext(infile)[1].lower())
    text=""
    try:
        if fn:text=fn(infile) or ""
    except Exception as e:
        sys.stderr.write(f"estfx: {os.path.basename(infile)}: {e}\n")
    open(outfile,"w",encoding="utf-8").write(text)

if __name__=="__main__":
    main()
