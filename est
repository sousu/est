#!/usr/bin/env python3
"""est - HyperEstraier コマンドラッパー"""
import sys
import os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from lib import config as cfg
from lib import commands as cmds

USAGE = """\
est: estcmd wrapper
  list                  ジャンルの一覧表示
  check    <genre>      登録対象ファイルの表示
  gather   <genre>      インデックス登録
  purge    <genre>      インデックス削除
  regather <genre>      purgeからgather
  reject   <path>       指定パスのみ削除し再gather
  merge                 全genreを casket_merged に統合
  publish               casket_merged を公開フォルダへ反映
  build                 Webメニューを生成
  optimize              casket_merged の最適化
"""

CMDS = {
    "list":     cmds.cmd_list,
    "check":    cmds.cmd_check,
    "gather":   cmds.cmd_gather,
    "purge":    cmds.cmd_purge,
    "regather": cmds.cmd_regather,
    "reject":   cmds.cmd_reject,
    "merge":    cmds.cmd_merge,
    "publish":  cmds.cmd_publish,
    "build":    cmds.cmd_build,
    "optimize": cmds.cmd_optimize,
}

def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(USAGE); return
    sub = args[0]
    if sub not in CMDS:
        print(f"unknown command: {sub}\n{USAGE}", file=sys.stderr); sys.exit(1)
    conf = cfg.load()
    CMDS[sub](conf, args[1:])

if __name__ == "__main__":
    main()
