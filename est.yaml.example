config:
  encoding: UTF-8

# genres: ジャンル毎に登録対象を定義（以下はサンプル）
# 実運用時は est.yaml にコピーして編集する（est.yaml は .gitignore 対象）
genres:
  sample_a:
    - dirPath: /target/sample
      indexName: サンプルインデックスA
      depth: 2
      regex: ""
      exregex: ""
  sample_b:
    - dirPath: /target/docs
      indexName: サンプルインデックスB
      depth: 2
      regex: ""
      exregex: ""
